{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-engine",
      "type": "shell",
      "command": "C:/Program1/c++/msys64/ucrt64/bin/g++.exe",
      "args": [
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-g",

        "${workspaceFolder}/engine/src/math/*.cpp",
        "${workspaceFolder}/engine/src/core/*.cpp",
        "${workspaceFolder}/engine/src/scene/*.cpp",
        "${workspaceFolder}/engine/src/graphics/*.cpp",
        "${workspaceFolder}/engine/src/helpers/*.cpp",
        "${workspaceFolder}/engine/src/platform/win32/Win32Main.cpp",
        "${workspaceFolder}/engine/src/platform/win32/Win32Window.cpp",

        "-I", "${workspaceFolder}/engine/include",

        "-lgdi32",

        "-o",
        "${workspaceFolder}/engine/output/Win32Main.exe"
      ],
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "run-engine",
      "type": "shell",
      "command": "${workspaceFolder}/engine/output/Win32Main.exe",
      "dependsOn": "build-engine",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      }
    }
  ]
}