        "CMAKE_C_COMPILER": "C:/Program1/c++/msys64/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/Program1/c++/msys64/ucrt64/bin/g++.exe",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ]
}